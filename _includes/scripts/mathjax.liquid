{% if site.enable_math %}
  {% unless page.pseudocode %}
    <!-- MathJax, see https://docs.mathjax.org/en/latest/input/tex/delimiters.html-->
    <script type="text/javascript">
      window.MathJax = {
        tex: {
          inlineMath: [
            ['$', '$'],
            ['\\(', '\\)'],
          ],
          displayMath: [
            ['$$', '$$'],
            ['\\[', '\\]'],
          ],
          processEscapes: true,
          processEnvironments: true,
          tags: 'ams',
        },
      };
    </script>
    <script
      defer
      type="text/javascript"
      id="MathJax-script"
      src="{{ site.third_party_libraries.mathjax.url.js }}"
    ></script>
    <script defer src="{{ site.third_party_libraries.polyfill.url.js }}"></script>
  {% endunless %}
{% endif %}
